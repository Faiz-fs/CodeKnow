# =============================================================================
# CodeKnow backend — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.
# =============================================================================

# --- App ---
APP_ENV=development
APP_PORT=8080
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# Local Postgres for now. Swap this URL for Supabase later — no code change.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codeknow_db

# --- GitHub OAuth ---
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL MUST be: http://localhost:8080/codeknow/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/codeknow/auth/github/callback

# --- Frontend redirect after OAuth (optional) ---
# If set, the callback redirects here with ?token=<jwt> (browser flow).
# If left blank, the callback returns JSON {access_token, user} (API flow).
FRONTEND_REDIRECT=

# --- Security ---
# JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=
# Fernet key for encrypting stored GitHub tokens.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Analysis tuning ---
MAX_COMMITS_TO_ANALYZE=500
GITHUB_CONCURRENT_REQUESTS=10
