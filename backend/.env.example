# =============================================================================
# CodeKnow backend — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.
# =============================================================================

# --- App ---
APP_ENV=development
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- GitHub OAuth ---
# Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email alerts) ---
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@codeknow.dev

# --- JWT signing (generate: openssl rand -hex 32) ---
JWT_SECRET=
